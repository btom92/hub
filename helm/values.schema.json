{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Values",
  "description": "Schema for the KNIME Business Hub ArgoCD Helm chart values. See values.yaml and CONFIGURABLE FIELDS for full documentation.",
  "type": "object",
  "properties": {
    "argocd": {
      "type": "object",
      "description": "ArgoCD configuration: project name, destination server, sync policy, and notifications.",
      "properties": {
        "projectName": { "type": "string", "description": "ArgoCD project name." },
        "destinationServer": { "type": "string", "description": "Default destination server for all Application resources." },
        "applicationNamespace": { "type": "string", "description": "Default namespace for all ArgoCD Application resources." },
        "applicationNameSuffix": { "type": "string", "description": "Optional suffix appended to all Application resource names." },
        "defaultRepoURL": { "type": "string", "description": "Default Helm chart repository URL." },
        "syncPolicy": {
          "type": "object",
          "description": "Default sync policy for all ArgoCD Application resources.",
          "properties": {
            "automated": {
              "type": "object",
              "properties": {
                "enabled": { "type": "boolean" },
                "prune": { "type": "boolean" },
                "selfHeal": { "type": "boolean" }
              }
            },
            "syncOptions": { "type": "array", "items": { "type": "string" } },
            "retry": {
              "type": "object",
              "properties": {
                "limit": { "type": "integer" },
                "backoff": {
                  "type": "object",
                  "properties": {
                    "duration": { "type": "string" },
                    "factor": { "type": "number" },
                    "maxDuration": { "type": "string" }
                  }
                }
              }
            }
          },
          "additionalProperties": true
        },
        "notifications": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "annotations": { "type": "object", "additionalProperties": { "type": "string" } }
          }
        }
      },
      "additionalProperties": false
    },
    "global": {
      "type": "object",
      "description": "Global configuration applied to all Helm charts (TLS, URLs, namespaces, postgres, metrics, etc.).",
      "properties": {
        "tls": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" }
          }
        },
        "caCertificate": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "configMapName": { "type": "string" }
          }
        },
        "urls": {
          "type": "object",
          "properties": {
            "webapp": { "type": "string" },
            "dataapps": { "type": "string" },
            "api": { "type": "string" },
            "auth": { "type": "string" },
            "websocket": { "type": "string" },
            "storage": { "type": "string" },
            "webapp_staging": { "type": "string" }
          }
        },
        "imageRegistry": { "type": "string" },
        "imagePullSecrets": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": { "name": { "type": "string" } }
          }
        },
        "metadata": {
          "type": "object",
          "properties": {
            "annotations": { "type": "object", "additionalProperties": { "type": "string" } },
            "labels": { "type": "object", "additionalProperties": { "type": "string" } }
          }
        },
        "namespaces": {
          "type": "object",
          "properties": {
            "core": { "type": "string" },
            "execution": { "type": "string" },
            "istio": { "type": "string" },
            "hub": { "type": "string" }
          }
        },
        "scheduling": {
          "type": "object",
          "properties": {
            "nodeSelector": { "type": "object" },
            "nodeAffinity": { "type": "object" },
            "tolerations": { "type": "object" }
          }
        },
        "metrics": {
          "type": "object",
          "properties": {
            "prometheus": {
              "type": "object",
              "properties": {
                "serviceMonitor": {
                  "type": "object",
                  "properties": {
                    "enabled": { "type": "boolean" },
                    "labels": { "type": "object" }
                  }
                },
                "podMonitor": {
                  "type": "object",
                  "properties": {
                    "enabled": { "type": "boolean" },
                    "labels": { "type": "object" }
                  }
                }
              }
            }
          }
        },
        "postgres": {
          "type": "object",
          "description": "Postgres clusters and database definitions. See values.yaml for structure.",
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "additionalCharts": {
      "type": "object",
      "description": "User-defined third-party Helm charts. Same field semantics as app-specific config; repoURL and targetRevision required per entry.",
      "additionalProperties": {
        "oneOf": [{ "$ref": "#/$defs/appConfig" }, { "type": "null" }]
      }
    }
  },
  "$defs": {
    "appConfig": {
      "type": "object",
      "description": "Per-chart configuration (app-specific or additionalCharts). CONFIGURABLE FIELDS in values.yaml.",
      "properties": {
        "enabled": { "type": "boolean", "description": "Whether the Helm chart is deployed." },
        "targetRevision": { "type": "string", "description": "Helm chart version to deploy." },
        "repoURL": { "type": "string", "description": "Helm chart repository URL (required for additionalCharts)." },
        "chartName": { "type": "string", "description": "Helm chart name (defaults to application name)." },
        "helmReleaseName": { "type": "string", "description": "Override the Helm release name." },
        "syncWave": { "type": "integer", "description": "Deployment order; lower values deploy earlier." },
        "syncPolicy": { "type": "object", "description": "ArgoCD sync policy for this application." },
        "namespace": { "type": "string", "description": "Namespace to deploy the chart to." },
        "ignoreDifferences": {
          "type": "array",
          "description": "Chart-specific ignoreDifferences for ArgoCD diffing.",
          "items": {
            "type": "object",
            "properties": {
              "group": { "type": "string" },
              "kind": { "type": "string" },
              "name": { "type": "string" },
              "jsonPointers": { "type": "array", "items": { "type": "string" } }
            },
            "additionalProperties": true
          }
        },
        "overrides": {
          "type": "object",
          "description": "Chart-specific Helm values overrides (merged with chart defaults).",
          "additionalProperties": true
        },
        "suppressGlobalValues": {
          "type": "boolean",
          "description": "When true, do not inject KNIME global values into this chart's valuesObject; only overrides are passed."
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": {
    "oneOf": [{ "$ref": "#/$defs/appConfig" }, { "type": "null" }]
  }
}
